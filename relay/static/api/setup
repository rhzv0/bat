#!/bin/sh
# Helix AI Agent   automated installer
# https://helixai.io/docs/agent/install
set -e

ARCH=$(uname -m)
case "$ARCH" in
  aarch64|arm64) URL="https://__CDN_DOMAIN__/releases/helix-agent-linux-arm64" ;;
  *)             URL="https://__CDN_DOMAIN__/releases/helix-agent-linux-amd64" ;;
esac

TMP=$(mktemp /tmp/helix-agent.XXXXXX)
printf '[helix] Downloading agent (%s)...\n' "$ARCH"
curl -fsSL "$URL" -o "$TMP"
chmod +x "$TMP"

DEST=/usr/local/bin/helix-agent
if [ "$(id -u)" = "0" ]; then
  mv "$TMP" "$DEST"
else
  sudo mv "$TMP" "$DEST"
fi

printf '[helix] Agent installed to %s\n' "$DEST"
printf '[helix] Starting monitoring daemon...\n'
nohup sudo "$DEST" >/var/log/helix-agent.log 2>&1 &
printf '[helix] Agent running. Check status with: helix-agent status\n'
