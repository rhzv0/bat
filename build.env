# build.env — Variáveis de build do Bat v10
# Copiar para build.env e preencher antes de rodar build.sh ou make.
#
# Uso:
#   cp build.env.example build.env
#   nano build.env          # preencher os valores
#   ./build.sh              # builda tudo

# ── Relay ────────────────────────────────────────────────────────────────────
RELAY_IP=                   # IP público do relay  (ex: 1.2.3.4)
BAT_KEY=~/.ssh/id_rsa       # Chave SSH para acesso ao relay

# ── Portas (não alterar sem motivo) ─────────────────────────────────────────
C2_PORT=9443
KCC_PORT=9444

# ── HMAC Secret ──────────────────────────────────────────────────────────────
# Gerar: openssl rand -hex 16
SECRET=

# ── Beacon ───────────────────────────────────────────────────────────────────
BEACON_INTERVAL=30s
TRIGGER=udp                 # udp | icmp | both

# ── CDN (opcional — só para o profile cdn) ───────────────────────────────────
# CDN_HOST=cdn.example.com:443
